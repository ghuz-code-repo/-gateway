# Environment variables for notification service
PORT=8082

# Database configuration
DB_HOST=notification-postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=notification_password
DB_NAME=notifications
DB_SSLMODE=disable

# SMTP configuration - managed via web interface, no defaults needed
# All SMTP settings are now stored in database and configured via admin panel
SMTP_DEBUG=false

# Notification processing settings - managed via web interface
# All processing settings are now stored in database and configured via admin panel

# Rate limiting settings
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10