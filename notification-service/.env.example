# Environment variables for notification service
# Copy this file to .env: cp .env.example .env
PORT=80

# Database configuration
DB_HOST=notification-postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=CHANGE_ME
DB_NAME=notifications
DB_SSLMODE=disable

# SMTP configuration
SMTP_HOST=CHANGE_ME_MAIL_SERVER_IP
SMTP_PORT=587
SMTP_USERNAME=robot@example.com
SMTP_PASSWORD=CHANGE_ME
SMTP_FROM=robot@example.com
SMTP_USE_TLS=false
SMTP_USE_AUTH=true
SMTP_AUTH_METHOD=login
SMTP_DEBUG=true

# Notification processing settings
MAX_RETRY_ATTEMPTS=3
BATCH_SIZE=10
DELAY_BETWEEN_BATCHES_MS=1000

# Rate limiting settings
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# Telegram Bot Configuration
# Regular bot for user notifications
TELEGRAM_BOT_TOKEN=CHANGE_ME
TELEGRAM_ENABLED=true

# System bot for alerts and monitoring (admins only)
TELEGRAM_SYSTEM_BOT_TOKEN=CHANGE_ME
TELEGRAM_SYSTEM_ENABLED=true

# System notification recipients
SYSTEM_EMAIL_RECIPIENT=admin@example.com
SYSTEM_TELEGRAM_USERNAME=@your_telegram

# Toggle system notifications
SEND_SYSTEM_EMAIL_NOTIFICATIONS=true
SEND_SYSTEM_TELEGRAM_NOTIFICATIONS=true

# Bot info links
TELEGRAM_NOTIFICATIONS_BOT_LINK=@your_notifications_bot
TELEGRAM_ALERTS_BOT_LINK=@your_alerts_bot
