# ============================================
# MongoDB Authentication - Docker Compose Env
# ============================================
# This file is used by docker-compose.yaml for MongoDB credentials.
# CRITICAL: Change these passwords before deploying to production!
# Generate strong passwords: openssl rand -base64 32
#
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# ============================================

# MongoDB root administrator password (for healthchecks and admin scripts)
MONGO_ROOT_PASSWORD=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32

# MongoDB application user password (used by auth-service to connect)
# Must match the password in auth-service/.env MONGO_URI
MONGO_APP_PASSWORD=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32
