# ============================================
# SECURITY CRITICAL - PRODUCTION CONFIGURATION
# ============================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# ============================================

# MongoDB Configuration
# URI includes authentication credentials — CHANGE PASSWORDS IN PRODUCTION!
# The password here must match MONGO_APP_PASSWORD in !gateway/.env
# Generate a strong password: openssl rand -base64 32
MONGO_URI=mongodb://authservice:CHANGE_ME@mongo:27017/authdb?authSource=authdb
MONGO_DB=authdb

# JWT Secret - MUST BE CHANGED IN PRODUCTION!
# Generate a strong secret: openssl rand -base64 48
# CRITICAL: This must be at least 32 characters long!
# NOTE: Must be identical in auth-service, client_service, and referal!
JWT_SECRET="CHANGE_ME_GENERATE_WITH_openssl_rand_base64_48"

# Environment (development/production)
# When set to "production", enables security features:
# - Secure cookie flag (requires HTTPS)
# - Disables verbose logging
ENVIRONMENT=development

# Base URL for the application
BASE_URL=http://localhost

# CORS Configuration
# Allowed origin for CORS requests
# In production, set this to your actual frontend URL
ALLOWED_ORIGIN=http://localhost

# ============================================
# Email Configuration
# ============================================
# Fallback settings (primary config is in notification-service database)
# These settings are used only when notification-service is unavailable

# Admin notifications
ADMIN_EMAIL=admin@example.com

SUPPORT_EMAIL='admin@example.com'
SUPPORT_TELEGRAM='@your_telegram'

# ============================================
# Service Monitoring Configuration
# ============================================
# Enable/disable service health monitoring
MONITORING_ENABLED=true

# Enable/disable sending monitoring notifications (Telegram + Email)
# Set to false to disable alerts but keep monitoring active
MONITOR_SEND_NOTIFICATIONS=true

# Admin Telegram chat ID for alerts
ADMIN_TELEGRAM_CHAT_ID=CHANGE_ME

# Admin email for monitoring alerts
MONITOR_ADMIN_EMAIL=admin@example.com

# Notification service URL
NOTIFICATION_SERVICE_URL=http://notification-service:80

# How often to check service health (in seconds)
MONITOR_CHECK_INTERVAL_SECONDS=30

# Cooldown period between alerts for same service (in minutes)
MONITOR_ALERT_COOLDOWN_MINUTES=10

# ============================================
# Internal API Key for Service-to-Service Communication
# ============================================
# All /api/* endpoints require this key in X-API-Key header
# MUST be changed in production! Generate: openssl rand -base64 32
INTERNAL_API_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32
