# Monitoring Service Configuration
# Copy this file to .env: cp .env.example .env
PORT=80

# Services to monitor (format: name:health_url,name2:health_url2)
MONITORED_SERVICES=auth-service:http://auth-service:80/health,notification-service:http://notification-service:80/api/v1/health,referral-service:http://referal:80/health,client-service:http://client-service-service:80/health

# Monitoring settings
CHECK_INTERVAL_SECONDS=30
HEALTH_CHECK_TIMEOUT_SECONDS=10
PERSISTENT_ALERT_THRESHOLD=20
ENABLE_PERSISTENT_ALERTS=false

# Notification service integration
NOTIFICATION_SERVICE_URL=http://notification-service:80

# System notification settings
# WARNING: Set these to false to disable all monitoring alerts!
SYSTEM_EMAIL_RECIPIENT=admin@example.com
SYSTEM_TELEGRAM_USERNAME=@your_telegram
SEND_SYSTEM_EMAIL_NOTIFICATIONS=true
SEND_SYSTEM_TELEGRAM_NOTIFICATIONS=true

# Logging
GIN_MODE=release
